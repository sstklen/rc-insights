{
  "name": "rc-insights",
  "version": "1.0.0",
  "description": "AI-powered subscription health report generator for RevenueCat's Charts API v2",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "rc-insights": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "analyze": "bun run src/index.ts analyze"
  },
  "keywords": [
    "revenuecat",
    "subscription",
    "analytics",
    "health-report",
    "cli",
    "charts-api",
    "mrr",
    "churn",
    "saas-metrics"
  ],
  "license": "MIT",
  "author": "Dr. Claw",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  }
}
